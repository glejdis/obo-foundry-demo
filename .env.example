# ==== Foundry project (used by both OBO agents) ====
PROJECT_ENDPOINT="https://<resource>.services.ai.azure.com/api/projects/<project>"
MODEL_DEPLOYMENT_NAME="gpt-4o-mini"

# ==== obo-demo Entra app registration ====
# Overview blade -> Directory (tenant) ID
TENANT="your-tenant-id"
# Overview blade -> Application (client) ID
CLIENT_ID="d03a0769-69cf-4601-afd6-2ba5f92aeadd"
# Certificates & secrets -> secret Value (copy at creation)
CLIENT_SECRET="your-client-secret-value"

# ==== Flow B: custom MCP server (used by filial_agent_mcp.py) ====
# MCP_SERVER_URL points filial_agent_mcp.py at the MCP server.
# Defaults to http://127.0.0.1:8000/mcp (local). Set to the deployed URL to use it.
# MCP_SERVER_URL="https://aldi-store-ops-mcp.blackbeach-39f4dfc4.swedencentral.azurecontainerapps.io/mcp"
